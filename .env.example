# === App ===
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# === Database (PostgreSQL) ===
DATABASE_URL=postgresql://user:password@localhost:5432/smartmessage

# === Redis (BullMQ + WA instance registry) ===
REDIS_URL=redis://localhost:6379

# === Auth ===
# HMAC-ключ подписи сессионной куки (apps/web/app/lib/auth.ts). Минимум 32 символа.
SESSION_SECRET=change_me_to_a_random_string_at_least_32_chars

# === WhatsApp (Baileys, см. docs/adr/0001) ===
WORKER_INTERNAL_API_TOKEN=change_me_to_a_random_internal_token
# Стабильный ID deployment-слота: переиспользовать после рестарта, не дублировать между живыми worker-процессами.
WA_WORKER_ID=worker-local-1
WA_OWNER_TTL_MS=30000
WA_RATE_LIMIT_PER_MIN=20

# === Billing (Merchant of Record, см. docs/adr/0002) ===
PAYMENT_PROVIDER=paddle
PAYMENT_API_KEY=change_me
PAYMENT_WEBHOOK_SECRET=change_me

# === AI ===
OPENAI_API_KEY=change_me
