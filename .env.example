# === App ===
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# === Database (PostgreSQL) ===
DATABASE_URL=postgresql://user:password@localhost:5432/smartmessage

# === Redis (BullMQ + WA instance registry) ===
REDIS_URL=redis://localhost:6379

# === Auth ===
JWT_SECRET=change_me
JWT_EXPIRES_IN=15m

# === WhatsApp (Baileys, см. docs/adr/0001) ===
WA_SESSION_DIR=./wa-sessions
WA_RATE_LIMIT_PER_MIN=20

# === Billing (Merchant of Record, см. docs/adr/0002) ===
PAYMENT_PROVIDER=paddle
PAYMENT_API_KEY=change_me
PAYMENT_WEBHOOK_SECRET=change_me

# === AI ===
OPENAI_API_KEY=change_me
